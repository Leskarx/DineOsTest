# ================================================================
#  Dine&Stay OS — Environment Variable Reference
#  Copy this file:  cp .env.example .env   then fill in values.
#  Never commit your .env to version control.
# ================================================================

# ─── Superadmin ───────────────────────────────────────────────────
SUPERADMIN_EMAIL=superadmin@dinestay.app
SUPERADMIN_PASSWORD=Admin@123   # ⚠ Change before going to production

# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=development           # development | production | test
APP_NAME="Dine&Stay OS"
APP_URL=http://localhost:3000  # Public URL of the web app
#   Multiple origins (comma-separated) are supported for CORS:
#   APP_URL=https://pos.yourdomain.com,https://kds.yourdomain.com
API_URL=http://localhost:4000  # Public URL of the NestJS API
NEXT_PUBLIC_API_HOST=          # Production hostname only (e.g. api.yourdomain.com) — used for Next.js image allowlist

# ─── Database (PostgreSQL) ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=dinestayadmin
DB_PASSWORD=changeme           # ⚠ Use a strong password in production
DB_NAME=dinestay
DB_SSL=false                   # Set to true for Supabase / RDS / managed DBs
DATABASE_URL=postgresql://dinestayadmin:changeme@localhost:5432/dinestay

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                # Leave blank for no-auth local Redis

# ─── Auth / JWT ───────────────────────────────────────────────────
# ⚠ Generate with:  openssl rand -base64 64
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRY=7d

# ─── Storage Driver ───────────────────────────────────────────────
# Options:
#   local  → saves to ./uploads on the API server (default, zero config)
#   s3     → works with AWS S3, MinIO (private VPS), R2, DO Spaces
STORAGE_DRIVER=local

# ── AWS S3 (STORAGE_DRIVER=s3, S3_ENDPOINT blank) ────────────────
S3_BUCKET=dinestay-assets
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=                 # Optional CDN URL prefix; auto-detected if blank

# ── MinIO on private VPS (STORAGE_DRIVER=s3, S3_ENDPOINT set) ─────
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=dinestay-assets
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=changeme
# S3_PUBLIC_URL=http://your-vps-ip:9000/dinestay-assets

# ── MinIO credentials (Docker service) ───────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme   # ⚠ Change in production

# ─── Email / SMTP ─────────────────────────────────────────────────
# Leave SMTP_HOST blank → emails are logged to console (safe for dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Dine&Stay OS <noreply@dinestay.app>"

# ─── SMS / OTP (MSG91) ───────────────────────────────────────────
# Leave MSG91_AUTH_KEY blank → OTPs are logged to console (safe for dev)
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=DNSTAY

# ─── Payments (Razorpay) ─────────────────────────────────────────
# Leave blank if not using Razorpay subscription billing
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxx

# ─── Next.js (web app) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Feature Flags ───────────────────────────────────────────────
ENABLE_MULTI_BRANCH=true
ENABLE_HOTEL_MODULE=false

# ─── Database Backups ────────────────────────────────────────────
# The API runs a pg_dump every day at 2 AM IST automatically.
# Set BACKUP_ENABLED=false to disable the scheduled job.
BACKUP_ENABLED=true
BACKUP_DIR=./backups                  # Local path to store dump files
BACKUP_RETENTION_DAYS=30              # Delete local dumps older than N days

# To also upload dumps to S3/R2/MinIO, set these:
# BACKUP_S3_BUCKET=dinestay-backups
# BACKUP_S3_PREFIX=db-backups         # Folder prefix inside the bucket
# BACKUP_S3_REGION=ap-south-1
# BACKUP_S3_ACCESS_KEY=               # Falls back to S3_ACCESS_KEY if blank
# BACKUP_S3_SECRET_KEY=               # Falls back to S3_SECRET_KEY if blank
# BACKUP_S3_ENDPOINT=                 # Set for MinIO/R2, blank for AWS S3

# ─── Sentry Error Tracking ───────────────────────────────────────
# Create a project at https://sentry.io → Settings → Projects → DSN
# Leave blank to disable Sentry (safe for local development).

# API (server-side)
SENTRY_DSN=
SENTRY_ORG=                           # Your Sentry org slug (for source maps)
SENTRY_PROJECT=dinestay-api           # Your Sentry project slug
SENTRY_RELEASE=                       # Set to git SHA in CI: $(git rev-parse HEAD)
SENTRY_AUTH_TOKEN=                    # Required for source map uploads in CI

# Web (client-side) — NEXT_PUBLIC_ prefix makes it available in the browser
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_PROJECT_WEB=dinestay-web

# ─── Docker standalone build ─────────────────────────────────────
# Uncomment when building for Docker/self-hosted production:
# NEXT_OUTPUT=standalone
